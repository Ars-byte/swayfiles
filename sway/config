# ---Autotiling---
exec_always python3 ~/.config/sway/scripts/autotiling
# --- Archivo de configuración de Sway ---
set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term kitty
set $menu ./.config/sway/scripts/launch
set $files thunar
set $wallpaper ./.config/sway/scripts/wallpaper.sh
floating_modifier $mod normal
for_window [app_id="waybar"] border none
for_window [app_id="waybar"] opacity 1
# Wallpaper
output * bg /home/clippy/Imágenes/wallpapers/burnout.png fill
bindsym $mod+Shift+p exec /home/clippy/.config/sway/scripts/wallpaper.sh prev
bindsym $mod+Shift+n exec /home/clippy/.config/sway/scripts/wallpaper.sh next
# Input
input "type:keyboard" {
    xkb_layout "latam"
}

# --- Key Bindings ---
bindsym $mod+Return exec $term
bindsym $mod+s exec $files 
bindsym $mod+Shift+q kill
bindsym $mod+d exec $menu

# Recargar y Salir
bindsym $mod+Shift+r reload
bindsym $mod+Shift+e exec swaynag -t warning -m '¿Quieres salir?' -B 'Sí' 'swaymsg exit'

# ANIMACIÓN DE BARRA: Mod+n para ocultar/mostrar suavemente
bindsym $mod+n exec killall -SIGUSR1 waybar

# Movimiento de foco
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10

# Move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number 1 
bindsym $mod+Shift+2 move container to workspace number 2 
bindsym $mod+Shift+3 move container to workspace number 3 
bindsym $mod+Shift+4 move container to workspace number 4 
bindsym $mod+Shift+5 move container to workspace number 5 
bindsym $mod+Shift+6 move container to workspace number 6 
bindsym $mod+Shift+7 move container to workspace number 7 
bindsym $mod+Shift+8 move container to workspace number 8 
bindsym $mod+Shift+9 move container to workspace number 9 
bindsym $mod+Shift+0 move container to workspace number 10

# Layouts
bindsym $mod+b splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle

# Multimedia y Brillo
bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+

# Captura de pantalla
bindsym Print exec ~/.config/sway/scripts/screenshot.sh

# --- Apariencia (Tu Estética) ---
exec waybar
gaps inner 3
gaps outer 3
#shadows enable
#shadow_blur_radius 20
#shadow_color #0000007f
#corner_radius 12
#smart_corner_radius on
#blur configs
blur enable
blur_radius 5
blur_passes 2
blur_radius 8
for_window [app_id="kitty"] {
    blur enable
    corner_radius 10  # Opcional: si quieres bordes redondeados ya que estás en SwayFX
}
# Blur específico para waybar
#layer_effects "waybar" blur enable
#layer_effects "waybar" shadows enable
#layer_effects "waybar" corner_radius 12
default_border none
for_window [class=".*"] border none
include /etc/sway/config.d/*
for_window [class="hl_linux"] floating enable, border none, fullscreen enable
